# ============================================================================
# SkyTakeOut 开发环境配置示例
# 使用说明：复制此文件为 application-dev.yml，并填入真实的配置值
# ============================================================================

sky:
  # ----------------------------------------------------------------------------
  # 数据库配置（MySQL）
  # ----------------------------------------------------------------------------
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    host: localhost
    port: 3306
    database: sky_take_out
    username: root
    password: ${DB_PASSWORD:your-database-password}  # 建议通过环境变量设置
  
  # ----------------------------------------------------------------------------
  # Redis 配置
  # ----------------------------------------------------------------------------
  redis:
    host: localhost
    port: 6379
    password: ${REDIS_PASSWORD:}  # 如果 Redis 没有密码，留空即可
  
  # ----------------------------------------------------------------------------
  # 阿里云 OSS 配置（图片存储）
  # ----------------------------------------------------------------------------
  alioss:
    endpoint: oss-cn-beijing.aliyuncs.com  # 根据你的 OSS 区域修改
    access-key-id: ${OSS_ACCESS_KEY_ID:your-access-key-id}
    access-key-secret: ${OSS_ACCESS_KEY_SECRET:your-access-key-secret}
    bucket-name: your-bucket-name
  
  # ----------------------------------------------------------------------------
  # 微信支付配置
  # ----------------------------------------------------------------------------
  wechat:
    appid: ${WECHAT_APPID:your-wechat-appid}
    secret: ${WECHAT_SECRET:your-wechat-secret}

# ============================================================================
# Spring AI 配置（大模型服务）
# 支持 SiliconFlow、DeepSeek、OpenAI 等兼容 OpenAI API 的服务
# ============================================================================
spring:
  ai:
    openai:
      # API Key（必填）
      api-key: ${OPENAI_API_KEY:your-openai-api-key}
      
      # API 基础地址（根据服务商修改）
      # SiliconFlow: https://api.siliconflow.cn/v1
      # DeepSeek:    https://api.deepseek.com/v1
      # OpenAI:      https://api.openai.com/v1
      base-url: https://api.siliconflow.cn/v1
      
      # 聊天模型配置
      chat:
        options:
          # 推荐模型：
          # - deepseek-ai/DeepSeek-V3（性价比高）
          # - deepseek-ai/DeepSeek-R1（推理能力强）
          # - Qwen/Qwen2.5-72B-Instruct（中文效果好）
          model: deepseek-ai/DeepSeek-V3
      
      # 向量模型配置（用于 RAG、语义搜索）
      embedding:
        options:
          # 推荐模型：
          # - BAAI/bge-m3（多语言、高性能）
          # - text-embedding-ada-002（OpenAI）
          model: BAAI/bge-m3

# ============================================================================
# 配置提示
# ============================================================================
# 1. 环境变量方式（推荐，更安全）：
#    export DB_PASSWORD=your-real-password
#    export OPENAI_API_KEY=sk-xxxxx
#    mvn spring-boot:run
#
# 2. 直接填写方式（仅用于本地开发测试）：
#    将 ${DB_PASSWORD:your-database-password} 改为 your-real-password
#
# 3. 常用 API 服务商：
#    - SiliconFlow: https://cloud.siliconflow.cn（国内访问快，有免费额度）
#    - DeepSeek:    https://platform.deepseek.com（国产优秀模型）
#    - OpenAI:      https://platform.openai.com（需要海外网络）
#
# 4. 获取 API Key 后，建议设置为环境变量，避免泄露到代码仓库
# ============================================================================
