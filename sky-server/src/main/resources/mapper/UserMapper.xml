<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.sky.mapper.UserMapper">
    <insert id="insert" useGeneratedKeys="true" keyColumn="id" keyProperty="id">
            insert into sky_take_out.user (openid, name, phone, sex, id_number, avatar, create_time)
            values (#{openid}, #{name}, #{phone}, #{sex}, #{idNumber}, #{avatar}, #{createTime})
    </insert>


    <select id="getByOpenid" resultType="com.sky.entity.User">
        select * from sky_take_out.user where openid = #{openid}
    </select>
    <select id="getById" resultType="com.sky.entity.User">
        select * from sky_take_out.user where id = #{id}
    </select>

    <update id="updateById" parameterType="com.sky.entity.User">
        update sky_take_out.user
        <set>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="phone != null and phone != ''">phone = #{phone},</if>
            <if test="sex != null and sex != ''">sex = #{sex},</if>
            <if test="idNumber != null and idNumber != ''">id_number = #{idNumber},</if>
            <if test="avatar != null and avatar != ''">avatar = #{avatar},</if>
        </set>
        where id = #{id}
    </update>
</mapper>